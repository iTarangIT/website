# ---- ElevenLabs AI caller (iTarang Admin → Partner Network Growth → AI caller) ----
# Server-side API key. Never committed. Get it from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ---- OpenAI intent scoring (runs after each completed AI call) ----
# Server-side API key. Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Override the model used for scoring. Default: gpt-5.1-mini
OPENAI_INTENT_MODEL=gpt-5.1-mini

# ---- Existing integrations (only needed if you touch the chatbot / knowledge base) ----
GROQ_API_KEY=
OPENAI_API_KEY=
PINECONE_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
FIRECRAWL_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
